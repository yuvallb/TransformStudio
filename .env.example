# Optional: Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# Leave unset in local dev to disable analytics.
VITE_GA_MEASUREMENT_ID=

# Optional: Google Search Console HTML-tag verification token (content value only).
# Injected into index.html at build time; not committed to the repo.
VITE_GSC_SITE_VERIFICATION=

# Optional: enable Custom Python node (post-M9 power feature, off by default)
# VITE_ENABLE_CUSTOM_PYTHON=true
